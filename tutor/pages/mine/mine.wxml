<view class="container">
  <view class="profile-section">
    <view wx:if="{{!userInfo}}" class="login-prompt">
      <text class="login-text">登录</text>
      <button class="login-btn" open-type="getUserProfile" bindgetuserinfo="handleLogin">
        微信 登录
      </button>
    </view>

    <view wx:else class="profile-info">
      <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
      <text class="user-name">{{userInfo.nickName}}</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="goToConsult">
      <text class="menu-icon">💬</text>
      <text class="menu-text">一对一专属客服咨询</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="favorites-section">
    <view class="section-header">
      <text class="section-title">我的收藏</text>
      <text class="section-count">{{favoriteTutors.length}}</text>
    </view>

    <view wx:if="{{favoriteTutors.length === 0}}" class="empty-state">
      <text class="empty-text">No favorites yet</text>
    </view>

    <view wx:else class="favorites-list">
      <view wx:for="{{favoriteTutors}}" wx:key="_id" class="favorite-item"
        bindtap="goToDetail" data-id="{{item._id}}">
        <image class="favorite-avatar" src="{{item.avatar}}" mode="aspectFill" />
        <view class="favorite-info">
          <view class="favorite-name">{{item.name}}</view>
          <view class="favorite-subject">{{item.subject}} • {{item.grade}}</view>
          <view class="favorite-fee">{{item.feeRange}}</view>
        </view>
      </view>
    </view>
  </view>
</view>