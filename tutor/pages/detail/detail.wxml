<view class="container">
  <view class="detail-header">
    <image class="detail-avatar" src="{{tutor.avatar}}" mode="aspectFill" />
    <view class="header-info">
      <view class="tutor-name">{{tutor.name}}</view>
      <view class="tutor-university">{{tutor.university}}</view>
      <view class="rating-container">
        <text class="rating">⭐ {{tutor.rating}}</text>
        <text class="reviews">({{tutor.totalReviews}} reviews)</text>
      </view>
    </view>
  </view>

  <view class="detail-section">
    <view class="section-title">基本信息</view>
    <view class="info-row">
      <text class="info-label">教员id:</text>
      <text class="info-value">{{tutor.id}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">状态:</text>
      <text class="info-value fee">{{tutor.state}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">教学科目:</text>
      <text class="info-value">{{tutor.subject}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">教学年级:</text>
      <text class="info-value">{{tutor.grade}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">方便的时间:</text>
      <text class="info-value">{{tutor.availableTime}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">预期价格:</text>
      <text class="info-value fee">{{tutor.feeRange}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">详细信息:</text>
      <view bindtap="viewPdf" class="pdf-btn">PDF</view>
    </view>
  </view>

  <view class="detail-section">
    <view class="section-title">教员亮点</view>
    <text class="features-text">{{tutor.features}}</text>
  </view>

  <view class="action-buttons">
    <button class="btn-favorite {{isFavorited ? 'favorited' : ''}}" bindtap="toggleFavorite">
      {{isFavorited ? '❤️ Favorited' : '🤍 Favorite'}}
    </button>
    <button class="btn-consult" bindtap="goToConsult">
      💬 点击咨询
    </button>
  </view>
</view>